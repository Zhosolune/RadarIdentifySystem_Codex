/* style/slice_interface.qss */
QFrame#sliceInterface {
    background-color: transparent;
    border: none;
}

QWidget#sliceLeftColumn,
QWidget#sliceMiddleColumn,
QWidget#sliceRightColumn {
    background-color: transparent;
    border: none;
}

QLabel#sliceLeftTitle,
QLabel#sliceMiddleTitle {
    font-size: 18px;
    font-weight: 700;
    color: --ThemeColorPrimary;
}

QLabel#sliceDimensionLabel {
    font-size: 16px;
    color: --ThemeColorPrimary;
}

SimpleCardWidget#sliceImageCard {
    background-color: rgba(255, 255, 255, 0.72);
    border: 1px solid --ThemeColorPrimary;
    border-radius: 6px;
    min-height: 120px;
}
